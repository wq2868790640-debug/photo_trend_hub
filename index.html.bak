                        </button>
                    </div>

                    <div class="grid grid-cols-2 gap-4">
                        <div>
                            <label class="eyebrow eyebrow-mute block mb-2">Type · 维度</label>
                            <select id="f-type" required></select>
                        </div>
                        <div>
                            <label class="eyebrow eyebrow-mute block mb-2">Media · 媒介</label>
