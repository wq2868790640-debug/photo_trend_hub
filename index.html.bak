                    </div>
                    <button type="button" id="btn-open-bookmarklet"
                        class="eyebrow text-ink-mute hover:text-ink transition flex items-center gap-1.5"
                        title="安装一键收藏书签">
                        <i class="fa-solid fa-bookmark text-[10px]"></i>
                        <span>Bookmarklet</span>
                    </button>
