<!DOCTYPE html>
<html lang="zh-CN">
<head>
<meta charset="UTF-8">
  <meta http-equiv="Cache-Control" content="no-cache, no-store, must-revalidate">
    <meta http-equiv="Pragma" content="no-cache">
      <meta http-equiv="Expires" content="0">
        <title>Photo Trend Hub · 当代与商业摄影趋势中台</title>
<meta name="viewport" content="width=device-width,initial-scale=1">

<!-- Tailwind CDN -->
<script src="https://cdn.tailwindcss.com"></script>

<!-- FontAwesome 图标 -->
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">

<!-- 杂志衬线 + 现代无衬线 + 中文宋体 -->
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,500;0,600;1,300;1,400&family=Inter:wght@300;400;500;600;700&family=Noto+Serif+SC:wght@300;400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet">

<script>
// Tailwind 主题 · 美术馆白墙杂志调
tailwind.config = {
    theme: {
        extend: {
            fontFamily: {
                serif: ['"Cormorant Garamond"','"Noto Serif SC"','serif'],
                sans:  ['Inter','"Noto Serif SC"','system-ui','sans-serif'],
                mono:  ['"JetBrains Mono"','monospace']
            },
            colors: {
                paper:      '#fafaf8',  // 主背景：暖米白
                'paper-soft':'#f0eeea', // 次背景：淡米灰
                ink:        '#0a0a0a',  // 主文字：带温度的深炭
                'ink-soft': '#5a5754',  // 副文字
                'ink-mute': '#a8a39c',  // 极小标 · 占位符
                line:       '#e8e6e0',  // 1px 分割线
                'line-strong':'#0a0a0a' // hover 描边
            },
            letterSpacing: {
                tightest: '-0.04em',
                editorial:'0.18em',
                wider2:   '0.3em'
            }
        }
    }
};
</script>

<style>
    /* ============================================================= */
    /* 美术馆白墙 · 杂志 Editorial 范式                                 */
    /* ============================================================= */
    html, body {
        background: #fafaf8;
        scroll-behavior: smooth;
    }

    body {
        color: #0a0a0a;
        font-family: 'Inter', 'Noto Serif SC', system-ui, sans-serif;
        font-weight: 400;
        -webkit-font-smoothing: antialiased;
        text-rendering: optimizeLegibility;
    }

    /* 容器宽度 */
    .container-x { max-width: 1440px; margin-left:auto; margin-right:auto; padding-left: clamp(1rem, 4vw, 4rem); padding-right: clamp(1rem, 4vw, 4rem); }
    .container-narrow { max-width: 1200px; margin-left:auto; margin-right:auto; padding-left: clamp(1rem, 4vw, 4rem); padding-right: clamp(1rem, 4vw, 4rem); }

    /* 衬线大字 · 杂志主标语法 */
    h1, h2, h3, .serif {
        font-family: 'Cormorant Garamond', 'Noto Serif SC', serif;
        font-weight: 400;
        letter-spacing: -0.01em;
        font-feature-settings: "liga" 1, "kern" 1;
    }
    .serif-italic { font-style: italic; font-weight: 300; }

    /* 极小标 · 杂志小标语法 */
    .eyebrow {
        font-family: 'Inter', sans-serif;
        font-size: 11px;
        font-weight: 500;
        letter-spacing: 0.18em;
        text-transform: uppercase;
        color: #5a5754;
    }
    .eyebrow-mute { color: #a8a39c; }

    /* hairline 杂志感细线 */
    .hairline        { border: 1px solid #e8e6e0; }
    .hairline-b      { border-bottom: 1px solid #e8e6e0; }
    .hairline-t      { border-top: 1px solid #e8e6e0; }
    .hairline-strong { border: 1px solid #0a0a0a; }

    /* 输入框 · 极致克制 */
    input, select, textarea {
        background: transparent;
        color: #0a0a0a;
        border: 0;
        outline: 0;
        border-bottom: 1px solid #d8d5cf;
        padding: 8px 0;
        width: 100%;
        font-family: inherit;
        transition: border-color 240ms ease;
    }
    input:focus, select:focus, textarea:focus {
        border-bottom-color: #0a0a0a;
    }
    select option { background:#fafaf8; color:#0a0a0a; }
    input[type=number]::-webkit-inner-spin-button,
    input[type=number]::-webkit-outer-spin-button { -webkit-appearance:none; margin:0; }
    input[type=number] { -moz-appearance: textfield; }
    ::placeholder { color: #a8a39c; }

    /* 自定义滚动条（白底版） */
    ::-webkit-scrollbar { width: 8px; height: 8px; }
    ::-webkit-scrollbar-track { background: transparent; }
    ::-webkit-scrollbar-thumb { background: #d8d5cf; border-radius: 4px; }
    ::-webkit-scrollbar-thumb:hover { background: #a8a39c; }

    /* ============================================================= */
    /* 横版 Editorial 卡片（核心改造）                                  */
    /* ============================================================= */
    .editorial-card {
        display: grid;
        grid-template-columns: 5fr 4fr;
        gap: clamp(2rem, 5vw, 5rem);
        align-items: end;            /* 关键：文字与图片底对齐 */
        padding: clamp(2.5rem, 6vw, 5rem) 0;
        border-bottom: 1px solid #e8e6e0;
    }
    .editorial-card:last-child { border-bottom: 0; }
    @media (max-width: 768px) {
        .editorial-card {
            grid-template-columns: 1fr;
            gap: 1.5rem;
            align-items: start;
        }
    }

    .editorial-img-wrap {
        position: relative;
        width: 100%;
        aspect-ratio: 16 / 10;
        overflow: hidden;
        background: #f0eeea;
    }
    .editorial-img-wrap img {
        position: absolute; inset: 0;
        width: 100%; height: 100%;
        object-fit: cover;
        transition: transform 1200ms cubic-bezier(.2,.7,.2,1);
    }
    .editorial-card:hover .editorial-img-wrap img { transform: scale(1.025); }

    /* 占位艺术块 */
    .art-placeholder {
        position: absolute; inset: 0;
        display: flex; align-items: center; justify-content: center;
        background:
            linear-gradient(135deg, rgba(0,0,0,0.025) 0%, transparent 100%),
            repeating-linear-gradient(45deg, rgba(0,0,0,0.02) 0 1px, transparent 1px 12px);
        color: #a8a39c;
    }

    /* 卡片标题：衬线大字 */
    .editorial-title {
        font-family: 'Cormorant Garamond', 'Noto Serif SC', serif;
        font-size: clamp(1.4rem, 2.4vw, 2rem);
        font-weight: 500;
        line-height: 1.35;
        color: #0a0a0a;
        letter-spacing: -0.005em;
    }

    /* hover 时浮现的元数据带 */
    .editorial-meta {
        opacity: 0;
        transform: translateY(8px);
        transition: opacity 500ms ease, transform 500ms cubic-bezier(.2,.7,.2,1);
    }
    .editorial-card:hover .editorial-meta {
        opacity: 1;
        transform: translateY(0);
    }

    /* ============================================================= */
    /* Tabs · 杂志类目栏                                               */
    /* ============================================================= */
    .tab-btn {
        position: relative;
        font-family: 'Inter', sans-serif;
        font-size: 11.5px;
        font-weight: 500;
        letter-spacing: 0.16em;
        text-transform: uppercase;
        color: #5a5754;
        padding: 12px 0;
        white-space: nowrap;
        transition: color 280ms ease;
    }
    .tab-btn::after {
        content:'';
        position: absolute;
        left: 50%;
        bottom: -1px;
        width: 0; height: 1px;
        background: #0a0a0a;
        transition: width 360ms cubic-bezier(.2,.7,.2,1), left 360ms cubic-bezier(.2,.7,.2,1);
    }
    .tab-btn:hover { color: #0a0a0a; }
    .tab-btn.is-active { color: #0a0a0a; }
    .tab-btn.is-active::after { width: 100%; left: 0; }

    /* ============================================================= */
    /* 按钮 · 极简描边                                                 */
    /* ============================================================= */
    .btn {
        display: inline-flex;
        align-items: center;
        gap: .55rem;
        padding: .7rem 1.2rem;
        font-size: 11px;
        font-weight: 500;
        letter-spacing: 0.18em;
        text-transform: uppercase;
        color: #0a0a0a;
        background: transparent;
        border: 1px solid #0a0a0a;
        cursor: pointer;
        transition: all 280ms ease;
    }
    .btn:hover {
        background: #0a0a0a;
        color: #fafaf8;
    }
    .btn-primary {
        background: #0a0a0a;
        color: #fafaf8;
        border-color: #0a0a0a;
    }
    .btn-primary:hover {
        background: #fafaf8;
        color: #0a0a0a;
    }
    .btn-ghost {
        border-color: #d8d5cf;
        color: #5a5754;
    }
    .btn-ghost:hover {
        border-color: #0a0a0a;
        color: #0a0a0a;
        background: transparent;
    }
    .btn-danger:hover {
        background: #0a0a0a;
        color: #fafaf8;
    }

    /* CTA 反白按钮（用于 Hero 2 黑底白字） */
    .btn-on-dark {
        color: #fafaf8;
        border-color: #fafaf8;
        background: transparent;
    }
    .btn-on-dark:hover {
        background: #fafaf8;
        color: #0a0a0a;
    }

    /* ============================================================= */
    /* Chip · 极简标签                                                 */
    /* ============================================================= */
    .chip {
        display: inline-flex;
        align-items: center;
        gap: .35rem;
        padding: 3px 10px;
        font-size: 10.5px;
        font-weight: 500;
        letter-spacing: 0.12em;
        text-transform: uppercase;
        color: #5a5754;
        background: transparent;
        border: 1px solid #d8d5cf;
        border-radius: 999px;
    }
    .chip-strong {
        color: #0a0a0a;
        border-color: #0a0a0a;
    }

    /* ============================================================= */
    /* 索引序号（杂志感）                                               */
    /* ============================================================= */
    .index-num {
        font-family: 'Cormorant Garamond', serif;
        font-weight: 300;
        font-style: italic;
        letter-spacing: -0.02em;
        color: #a8a39c;
    }

    /* 情绪权重 mini bar */
    .mood-bar { height: 1px; background: #e8e6e0; overflow:hidden; }
    .mood-bar > span { display:block; height:100%; background:#0a0a0a; }

    /* 入场动画 */
    @keyframes riseIn {
        from { opacity:0; transform: translateY(20px); }
        to   { opacity:1; transform: translateY(0); }
    }
    .rise-in { animation: riseIn 800ms cubic-bezier(.2,.7,.2,1) both; }

    /* Hero 2 主标入场（缓慢上浮 + blur 渐显） */
    @keyframes heroFadeIn {
        from { opacity:0; transform: translateY(24px); filter: blur(6px); }
        to   { opacity:1; transform: translateY(0);    filter: blur(0); }
    }
    .hero-fade { animation: heroFadeIn 1400ms cubic-bezier(.2,.7,.2,1) both; }

    /* 滚动指示符脉动 */
    @keyframes scrollHint {
        0%,100% { opacity: .4; transform: translateY(0); }
        50%     { opacity: 1;  transform: translateY(6px); }
    }
    .scroll-hint { animation: scrollHint 2.4s ease-in-out infinite; }

    details > summary { list-style: none; cursor: pointer; }
    details > summary::-webkit-details-marker { display:none; }

    /* 链接通用 */
    a { color: inherit; text-decoration: none; }
    a:hover { color: #0a0a0a; }

    /* 选中态 */
    ::selection { background: #0a0a0a; color: #fafaf8; }
</style>
</head>
<body class="font-sans">

<!-- ============================================================= -->
<!-- 极细顶栏 · 杂志刊头                                              -->
<!-- ============================================================= -->
<nav class="hairline-b">
    <div class="container-x py-4 flex items-center justify-between gap-6">
        <div class="flex items-center gap-2 text-ink-soft">
            <i class="fa-solid fa-camera-retro text-[14px]"></i>
            <span class="eyebrow">Photo Trend Hub</span>
        </div>
        <div class="hidden md:flex items-center gap-8">
            <a href="#hero" class="eyebrow hover:text-ink transition">序</a>
            <a href="#manifesto" class="eyebrow hover:text-ink transition">关于</a>
            <a href="#workspace" class="eyebrow hover:text-ink transition">中台</a>
            <a href="#archive" class="eyebrow hover:text-ink transition">档案</a>
        </div>
        <div class="flex items-center gap-3 text-ink-soft">
            <span id="stat-total" class="eyebrow">— Sources</span>
            <span class="text-line">·</span>
            <span id="stat-time" class="eyebrow font-mono normal-case tracking-normal">—</span>
        </div>
    </div>
</nav>


<!-- ============================================================= -->
<!-- HERO 1 · 左图右文 Editorial 序言                                 -->
<!-- ============================================================= -->
<section id="hero" class="container-x pt-16 md:pt-24 pb-20 md:pb-32">

    <!-- 巨大主标 · 杂志刊名感 -->
    <div class="text-center mb-16 md:mb-24">
        <div class="flex items-center justify-center gap-4 mb-6">
            <span class="inline-block w-10 h-px bg-ink/40"></span>
            <span class="eyebrow">Issue 01 — Contemporary Photography Atlas</span>
            <span class="inline-block w-10 h-px bg-ink/40"></span>
        </div>
        <h1 class="serif text-[clamp(3rem,9vw,7.5rem)] leading-[0.95] tracking-tightest text-ink">
            Photo Trend Hub
        </h1>
        <p class="serif serif-italic mt-5 text-[clamp(1.1rem,1.6vw,1.4rem)] text-ink-soft tracking-tight">
            一座关于当代影像与商业摄影的私人档案室。
        </p>
    </div>

    <!-- 左图右文 Editorial -->
    <div class="grid grid-cols-1 md:grid-cols-12 gap-10 md:gap-16 items-end">

        <!-- 左：4:5 当代/时尚摄影竖图 -->
        <figure class="md:col-span-6 rise-in">
            <div class="relative w-full overflow-hidden bg-paper-soft" style="aspect-ratio: 4/5;">
                <img
                    src="images/230227-leidinger-matthias-ad2186-8a-min-1440x1800.jpg"
                    alt="Contemporary editorial portrait · monochrome profile"
                    class="absolute inset-0 w-full h-full object-cover">
            </div>
            <figcaption class="eyebrow eyebrow-mute mt-3 flex items-center gap-2">
                <span class="inline-block w-4 h-px bg-ink-mute"></span>
                <span>Plate I · Editorial Reference</span>
            </figcaption>
        </figure>

        <!-- 右：编辑序言 -->
        <div class="md:col-span-6 rise-in" style="animation-delay:120ms">

            <div class="eyebrow mb-6">序 · Editorial Note</div>

            <h2 class="serif text-[clamp(1.8rem,2.6vw,2.6rem)] leading-[1.25] tracking-tightest text-ink mb-8">
                当代摄影与时尚摄影，一个向上追问，一个向下渗透——
                <span class="text-ink-soft">每一次画廊先锋的微小转身，都将在下一季的 campaign 中找到回声。</span>
            </h2>

            <div class="space-y-5 text-[14px] md:text-[15px] leading-[1.85] text-ink-soft max-w-prose">
                <p>
                    当代摄影，始于对"摄影何为"的持续追问——
                    它不再满足于记录眼见之物，而是以镜头为笔，在纪实与观念的边界上书写新的视觉语法。
                    从 1960 年代 <span class="text-ink">New Topographics</span> 的冷面凝视，
                    到 21 世纪 <span class="text-ink">AI 生成影像</span> 对"作者性"的挑战，
                    每一次范式转移都在重新定义摄影与真实的关系。
                </p>
                <p>
                    时尚摄影，则是商业与艺术最激烈的交锋地带。
                    它既是品牌欲望的发动机，也是时代审美的晴雨表——
                    <span class="text-ink">Helmut Newton</span> 的权力女性、
                    <span class="text-ink">Paolo Roversi</span> 的柔纱诗学、
                    <span class="text-ink">Glen Luchford</span> 的叙事大片，
                    每一位摄影师都在用快门重新回答同一个问题："衣服穿在谁身上、活在哪个世界里？"
                </p>
                <p>
                    本档案室的工作方法基于三个正交维度：
                    信息源类型学界定对象身份，
                    视觉语法分析拆解图像背后的技术决策，
                    商业降维周期预测其在视觉产业中的扩散速率。
                </p>
                <p class="serif serif-italic text-ink text-[16px] md:text-[17px] pt-2">
                    "We do not collect images. We collect the gestures that precede them."
                </p>
            </div>

            <!-- CTA 行 -->
            <div class="mt-10 flex flex-wrap items-center gap-4">
                <a href="#manifesto" class="btn btn-primary">
                    继续阅读
                    <i class="fa-solid fa-arrow-right text-[10px]"></i>
                </a>
                <a href="#workspace" class="btn btn-ghost">
                    跳至中台
                </a>
            </div>
        </div>
    </div>

    <!-- 滚动提示 -->
    <div class="mt-24 md:mt-32 flex justify-center scroll-hint">
        <div class="flex flex-col items-center gap-2 text-ink-mute">
            <span class="eyebrow eyebrow-mute">Continue</span>
            <i class="fa-solid fa-chevron-down text-[10px]"></i>
        </div>
    </div>
</section>


<!-- ============================================================= -->
<!-- HERO 2 · 全屏黑白沉浸式 Manifesto                                -->
<!-- ============================================================= -->
<section id="manifesto" class="relative w-screen h-screen overflow-hidden -mx-[max(0px,calc((100vw-100%)/2))]">
    <!-- 黑白底图：21:9 山海超宽幅 · 上半屏风景层 / 下半屏天然黑底文字层 -->
    <img
        src="images/230227-leidinger-matthias-ad2186-3-min-2048x1582.jpg"
        alt="Manifesto backdrop · monochrome landscape"
        class="absolute inset-0 w-full h-full object-cover"
        style="filter: grayscale(1) brightness(0.93) contrast(1.05);">

    <!-- 文字层：极简上下分层 · 顶部刊头 + 底部黑底文字组 -->
    <div class="relative h-full hero-fade">

        <!-- ① 顶部刊头：4vh → 落在最顶端 0-8% 极浅灰天空区，深色刊头 -->
        <div class="absolute left-0 right-0 flex items-center justify-center gap-4"
             style="top: 4.5vh;">
            <span class="inline-block w-12 h-px" style="background:rgba(10,10,10,0.42)"></span>
            <span class="eyebrow" style="color:rgba(10,10,10,0.72)">Contemporary · Trend Atlas</span>
            <span class="inline-block w-12 h-px" style="background:rgba(10,10,10,0.42)"></span>
        </div>

        <!-- ② 主文字组：紧凑垂直堆叠，整段锁在底部 25vh 内
             → 从 bottom: 8vh 起向上延伸约 26vh，全部落在前山黑剪影色面上
             → 主标使用单行（无 br）以缩短垂直高度，避免顶到 S 曲线弧上方
        -->
        <div class="absolute left-0 right-0 px-6 md:px-10 flex flex-col items-center text-center"
             style="bottom: 8vh;">

            <h2 class="serif font-light text-white text-[clamp(1.7rem,4.4vw,4rem)] leading-[1.12] tracking-tightest max-w-5xl">
                <span class="block">收纳每一道 <span class="serif-italic">当代影像</span> 的 视觉锚点</span>
                <span class="block serif-italic text-white/92 mt-1">从画廊先锋，到商业终章。</span>
            </h2>

            <span class="inline-block w-10 h-px mt-6 mb-5" style="background:rgba(255,255,255,0.55)"></span>

            <p class="max-w-xl text-white/88 text-[12.5px] md:text-[13.5px] leading-[1.85]"
               style="font-family:'Inter',sans-serif;">
                一个为视觉趋势中台而生的私人档案工具——采集你心动的每一帧，
                用专业语法标注它，让一年后的你仍能精准复盘其降维路径。
            </p>

            <div class="mt-6">
                <a href="#workspace" class="btn btn-on-dark">
                    进入档案
                    <i class="fa-solid fa-arrow-right text-[10px]"></i>
                </a>
            </div>
        </div>

        <!-- ③ 底部刊注：贴底 2.5vh → 最深纯黑区 -->
        <div class="absolute left-0 right-0 flex justify-center"
             style="bottom: 2.5vh;">
            <div class="flex items-center gap-3 eyebrow" style="color:rgba(255,255,255,0.5)">
                <span class="inline-block w-6 h-px" style="background:rgba(255,255,255,0.38)"></span>
                <span>Plate II · Manifesto</span>
                <span class="inline-block w-6 h-px" style="background:rgba(255,255,255,0.38)"></span>
            </div>
        </div>
    </div>
</section>


<!-- ============================================================= -->
<!-- 工作区 · Workspace                                              -->
<!-- ============================================================= -->
<main id="workspace" class="container-x pt-24 md:pt-32 pb-40">

    <!-- 工作区刊头 -->
    <div class="text-center mb-16 md:mb-24">
        <div class="flex items-center justify-center gap-4 mb-5">
            <span class="inline-block w-10 h-px bg-ink/40"></span>
            <span class="eyebrow">The Workspace</span>
            <span class="inline-block w-10 h-px bg-ink/40"></span>
        </div>
        <h2 class="serif text-[clamp(2.4rem,5vw,4rem)] leading-[1.05] tracking-tightest text-ink">
            档案 <span class="serif-italic">·</span> 中台
        </h2>
        <p class="serif serif-italic mt-4 text-[clamp(0.95rem,1.3vw,1.15rem)] text-ink-soft">
            采集 · 标注 · 聚类 · 周报。
        </p>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-12 gap-12 lg:gap-16">

        <!-- ============== 左：录入面板（Sticky） ============== -->
